# Normalize line endings: store LF in the repo, let Git convert on checkout.
# Without this, Windows checkouts get CRLF and `prettier --check` (endOfLine
# defaults to lf) flags every file. Text files committed as LF; binaries left
# untouched.
* text=auto eol=lf

# Explicit binary types — never normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.woff binary
*.woff2 binary
*.db binary
