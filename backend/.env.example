# ── OpenRouter ────────────────────────────────────────────────────────────────
# Get one at: https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Default model. Swap for haiku for cheap/fast mode.
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
# Optional headers reported to OpenRouter (helps with analytics/rate limit tiers).
OPENROUTER_REFERER=http://localhost:4000
OPENROUTER_TITLE=Intercom Triage

# ── Intercom (official REST API) ──────────────────────────────────────────────
# Workspace Access Token — the backend polls api.intercom.io directly with this
# (cross-package invariant #1). Create one under Intercom → Settings →
# Integrations → Developer Hub → your app → Authentication. Empty → backend boots
# degraded: no background poller, POST /tickets/sync returns 503.
INTERCOM_ACCESS_TOKEN=
INTERCOM_API_BASE=https://api.intercom.io
INTERCOM_API_VERSION=2.13
# Workspace slug (e.g. j3dxf22l) used only to build deep-link URLs. Not a secret.
INTERCOM_WORKSPACE_APP_ID=
# Background poll cadence in seconds. 0 = off (manual POST /tickets/sync only).
INTERCOM_POLL_INTERVAL_SECONDS=0
INTERCOM_POLL_CONCURRENCY=4
INTERCOM_CLOSURE_LOOKBACK_SECONDS=604800
INTERCOM_CONTACT_CACHE_TTL_SECONDS=300

# ── Model cascade (roadmap 2.2) ───────────────────────────────────────────────
# Route easy tickets to a cheap model; escalate low-confidence ones to the
# strong OPENROUTER_MODEL. Disabled by default (single strong-model call).
# Enable only after measuring the escalation rate on real traffic — a rate above
# ~40% makes the double call cost more than it saves (see /metrics:
# cascade_escalated_total / cascade_cheap_total).
CASCADE_ENABLED=false
OPENROUTER_CHEAP_MODEL=anthropic/claude-3.5-haiku
# Escalate when the cheap model's self-reported confidence is below this.
CASCADE_ESCALATE_BELOW=0.7

# ── Needs-review lane (roadmap 2.3) ───────────────────────────────────────────
# An open, non-overridden ticket whose categorization confidence is below this
# surfaces in the webapp "needs review" lane (a view-layer split over the
# existing ai_confidence — no schema change). Calibrated default 0.65; see
# backend/tests/test_review_calibration.py for the basis. The webapp mirrors
# this in webapp/src/utils/review.ts — keep them in sync.
REVIEW_CONFIDENCE_THRESHOLD=0.65

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default). For Postgres:
#   DATABASE_URL=postgresql+asyncpg://user:pass@host/dbname
DATABASE_URL=sqlite+aiosqlite:///./data/triage.db

# ── Behavior ──────────────────────────────────────────────────────────────────
MAX_TICKETS_PER_FETCH=100
AI_CONCURRENCY=4
CACHE_TTL_SECONDS=300

# ── Server ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Auth / sessions (Phase 1: hosted multi-user) ──────────────────────────────
# REQUIRED — backend refuses to boot without it. Generate a long random string.
SESSION_JWT_SECRET=
# Optional — Fernet key (urlsafe base64, 32 bytes) to encrypt the stored
# OnlySales refresh token. Generate:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SESSION_REFRESH_ENCRYPTION_KEY=
# OnlySales auth backend (login/refresh proxy target).
ONLYSALES_AUTH_BASE=https://pyapi.onlysales.io
# For plain-http LOCAL dev the refresh cookie must not be Secure-only:
SESSION_COOKIE_SECURE=false
