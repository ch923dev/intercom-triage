# ── Intercom ──────────────────────────────────────────────────────────────────
# Get one at: https://developers.intercom.com/ → Your Apps → Authentication
# Required scope: Read conversations
INTERCOM_ACCESS_TOKEN=

# ── OpenRouter ────────────────────────────────────────────────────────────────
# Get one at: https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Default model. Swap for haiku for cheap/fast mode.
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
# Optional headers reported to OpenRouter (helps with analytics/rate limit tiers).
OPENROUTER_REFERER=http://localhost:8000
OPENROUTER_TITLE=Intercom Triage

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default). For Postgres:
#   DATABASE_URL=postgresql+asyncpg://user:pass@host/dbname
DATABASE_URL=sqlite+aiosqlite:///./data/triage.db

# ── Behavior ──────────────────────────────────────────────────────────────────
DEFAULT_LOOKBACK_HOURS=24
MAX_TICKETS_PER_FETCH=100
AI_CONCURRENCY=4
CACHE_TTL_SECONDS=300

# ── Server ────────────────────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8000
LOG_LEVEL=INFO
